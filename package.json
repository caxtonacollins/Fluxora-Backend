{
  "name": "fluxora-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "k6:smoke": "k6 run -e PROFILE=smoke k6/main.js",
    "k6:load": "k6 run -e PROFILE=load k6/main.js",
    "k6:stress": "k6 run -e PROFILE=stress k6/main.js",
    "k6:soak": "k6 run -e PROFILE=soak k6/main.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.16",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
